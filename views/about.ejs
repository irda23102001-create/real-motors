<%- include('partials/header') %>

<div class="page-hero">
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content">
    <h1>About <span>Real Motors</span></h1>
    <p>Our story, our passion, our commitment</p>
    <nav class="breadcrumb">
      <a href="/">Home</a> <i class="fas fa-chevron-right"></i> <span>About Us</span>
    </nav>
  </div>
</div>

<section class="section about-intro">
  <div class="container">
    <div class="about-grid">
      <div class="about-text">
        <span class="section-tag">Our Story</span>
        <h2>Born From a Passion <span>for Automotive Excellence</span></h2>
        <p>Founded in 2016, Real Motors began as a small family business with a simple but powerful vision: to make quality vehicles accessible to everyone in Albania while delivering a dealership experience rooted in honesty, transparency, and genuine care.</p>
        <p>Over eight years, we've grown into Albania's most trusted automotive dealership, offering an exceptional range of pre-owned cars and motorbikes. But our core values remain the same as day one: put the customer first, never compromise on quality, and always be honest.</p>
        <p>Today, Real Motors serves clients from across Albania and beyond, with a reputation built on thousands of successful transactions and the trust of our community.</p>
        <div class="about-signature">
          <strong>Argjend Hoxha</strong>
          <span>Founder & Director, Real Motors</span>
        </div>
      </div>
      <div class="about-visual">
        <div class="about-img-block">
          <div class="about-img-main">
            <img src="/images/about-showroom.jpg" alt="Real Motors Showroom" onerror="this.style.background='linear-gradient(135deg,#1F3B6A,#2E4872)'; this.alt='Real Motors';">
          </div>
          <div class="about-stat-badge">
            <strong>8+</strong>
            <span>Years of Excellence</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Mission Vision Values -->
<section class="section mvv-section">
  <div class="container">
    <div class="mvv-grid">
      <div class="mvv-card">
        <div class="mvv-icon"><i class="fas fa-bullseye"></i></div>
        <h3>Our Mission</h3>
        <p>To provide every client with a vehicle they can trust, at a price that's fair, through a process that's transparent. We exist to make the car buying experience simple, honest, and enjoyable.</p>
      </div>
      <div class="mvv-card featured">
        <div class="mvv-icon"><i class="fas fa-eye"></i></div>
        <h3>Our Vision</h3>
        <p>To be Albania's most trusted and respected automotive dealership — a benchmark for quality, integrity, and customer satisfaction across the region.</p>
      </div>
      <div class="mvv-card">
        <div class="mvv-icon"><i class="fas fa-heart"></i></div>
        <h3>Our Values</h3>
        <p>Honesty, Quality, Respect, and Excellence guide every decision we make. We treat every customer the way we'd want to be treated — as family.</p>
      </div>
    </div>
  </div>
</section>

<!-- Team -->
<section class="section team-section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">The Team</span>
      <h2 class="section-title">Meet Our <span>Experts</span></h2>
      <p class="section-sub">Our team brings decades of combined automotive expertise to serve you better.</p>
    </div>
    <div class="team-grid">
      <div class="team-card">
        <div class="team-avatar"><i class="fas fa-user"></i></div>
        <h4>Argjend Hoxha</h4>
        <span>Founder & Director</span>
        <p>8 years leading Real Motors with a passion for automotive excellence and customer satisfaction.</p>
      </div>
      <div class="team-card">
        <div class="team-avatar"><i class="fas fa-user"></i></div>
        <h4>Besa Dervishi</h4>
        <span>Sales Manager</span>
        <p>Expert in matching clients with their perfect vehicle. Specialises in premium European brands.</p>
      </div>
      <div class="team-card">
        <div class="team-avatar"><i class="fas fa-user"></i></div>
        <h4>Klejdi Marku</h4>
        <span>Technical Inspector</span>
        <p>Certified mechanic with 12 years experience. Every car passes his rigorous 150-point inspection.</p>
      </div>
      <div class="team-card">
        <div class="team-avatar"><i class="fas fa-user"></i></div>
        <h4>Elona Cela</h4>
        <span>Client Relations</span>
        <p>Dedicated to ensuring every client has an exceptional experience from first contact to final handover.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="cta-bg"></div>
  <div class="container cta-content">
    <h2>Experience the Real Motors <span>Difference</span></h2>
    <p>Visit our showroom or book an appointment with our team today.</p>
    <div class="cta-actions">
      <a href="/inventory" class="btn btn-white btn-lg">Browse Inventory</a>
      <a href="/contact" class="btn btn-outline-white btn-lg">Contact Us</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
