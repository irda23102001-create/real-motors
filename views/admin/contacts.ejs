<%- include('partials/header', { activePage: 'contacts' }) %>

<div class="admin-page-header">
  <div>
    <h1><i class="fas fa-envelope"></i> Client Messages</h1>
    <p>Manage all contact and enquiry messages</p>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card-header">
    <h3>All Messages (<%= contacts.length %>)</h3>
    <input type="text" id="contactSearch" placeholder="Search..." class="admin-search">
  </div>
  <div class="admin-table-wrap">
    <table class="admin-table" id="contactTable">
      <thead>
        <tr>
          <th>Client</th>
          <th>Contact</th>
          <th>Message</th>
          <th>Status</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% contacts.forEach(c => { %>
        <tr>
          <td><strong><%= c.name %></strong></td>
          <td>
            <small><i class="fas fa-phone"></i> <a href="tel:<%= c.phone %>"><%= c.phone %></a></small><br>
            <small><i class="fas fa-envelope"></i> <a href="mailto:<%= c.email %>"><%= c.email %></a></small>
          </td>
          <td class="message-cell"><%= c.message ? c.message.substring(0, 100) + (c.message.length > 100 ? '...' : '') : '-' %></td>
          <td>
            <form action="/admin/contacts/status/<%= c.id %>" method="POST" class="inline-form">
              <select name="status" onchange="this.form.submit()" class="status-select">
                <option value="new" <%= c.status === 'new' ? 'selected' : '' %>>New</option>
                <option value="read" <%= c.status === 'read' ? 'selected' : '' %>>Read</option>
                <option value="replied" <%= c.status === 'replied' ? 'selected' : '' %>>Replied</option>
                <option value="archived" <%= c.status === 'archived' ? 'selected' : '' %>>Archived</option>
              </select>
            </form>
          </td>
          <td><small><%= new Date(c.created_at).toLocaleDateString() %></small></td>
          <td>
            <div class="action-btns">
              <a href="mailto:<%= c.email %>" class="action-btn view-btn" title="Reply via email"><i class="fas fa-reply"></i></a>
              <form action="/admin/contacts/delete/<%= c.id %>" method="POST" class="inline-form" onsubmit="return confirm('Delete this message?')">
                <button type="submit" class="action-btn delete-btn" title="Delete"><i class="fas fa-trash"></i></button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
        <% if (contacts.length === 0) { %>
        <tr><td colspan="6" class="empty-row">No messages yet.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
document.getElementById('contactSearch').addEventListener('input', function() {
  const val = this.value.toLowerCase();
  document.querySelectorAll('#contactTable tbody tr').forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(val) ? '' : 'none';
  });
});
</script>

<%- include('partials/footer') %>
