<%- include('partials/header', { activePage: 'appointments' }) %>

<div class="admin-page-header">
  <div>
    <h1><i class="fas fa-calendar-check"></i> Appointments</h1>
    <p>Manage all appointment requests</p>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card-header">
    <h3>All Appointments (<%= appointments.length %>)</h3>
    <input type="text" id="apptSearch" placeholder="Search..." class="admin-search">
  </div>
  <div class="admin-table-wrap">
    <table class="admin-table" id="apptTable">
      <thead>
        <tr>
          <th>Client</th>
          <th>Vehicle</th>
          <th>Date & Time</th>
          <th>Message</th>
          <th>Status</th>
          <th>Received</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% appointments.forEach(a => { %>
        <tr>
          <td>
            <strong><%= a.name %></strong><br>
            <small><i class="fas fa-phone"></i> <a href="tel:<%= a.phone %>"><%= a.phone %></a></small><br>
            <small><i class="fas fa-envelope"></i> <a href="mailto:<%= a.email %>"><%= a.email %></a></small>
          </td>
          <td><%= a.car_name || 'General Visit' %></td>
          <td>
            <%= a.appointment_date || 'Not specified' %><br>
            <small><%= a.appointment_time || '' %></small>
          </td>
          <td class="message-cell"><%= a.message ? a.message.substring(0, 80) + (a.message.length > 80 ? '...' : '') : '-' %></td>
          <td>
            <form action="/admin/appointments/status/<%= a.id %>" method="POST" class="inline-form">
              <select name="status" onchange="this.form.submit()" class="status-select">
                <option value="pending" <%= a.status === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="confirmed" <%= a.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                <option value="completed" <%= a.status === 'completed' ? 'selected' : '' %>>Completed</option>
                <option value="cancelled" <%= a.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
              </select>
            </form>
          </td>
          <td><small><%= new Date(a.created_at).toLocaleDateString() %></small></td>
          <td>
            <form action="/admin/appointments/delete/<%= a.id %>" method="POST" class="inline-form" onsubmit="return confirm('Delete this appointment?')">
              <button type="submit" class="action-btn delete-btn" title="Delete"><i class="fas fa-trash"></i></button>
            </form>
          </td>
        </tr>
        <% }) %>
        <% if (appointments.length === 0) { %>
        <tr><td colspan="7" class="empty-row">No appointments yet.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
document.getElementById('apptSearch').addEventListener('input', function() {
  const val = this.value.toLowerCase();
  document.querySelectorAll('#apptTable tbody tr').forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(val) ? '' : 'none';
  });
});
</script>

<%- include('partials/footer') %>
